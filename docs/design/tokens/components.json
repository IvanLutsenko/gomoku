{
  "buttons": {
    "$comment": "Редизайн 2026-07: форма «Округлые» (r=10), тон primary — «Киноварь» (TWEAK_DEFAULTS дизайн-проекта).",
    "primary": {
      "bg": "vermillion",
      "fg": "#f7f1e4",
      "border": null,
      "padding": [18, 24],
      "padding_compact": [13, 16],
      "font_style": "button",
      "corner_radius": 10,
      "min_height": 52
    },
    "secondary": {
      "bg": "transparent",
      "fg": "ink",
      "border": { "color": "line_firm", "width": 1 },
      "padding": [18, 24],
      "padding_compact": [13, 16],
      "font_style": "button",
      "corner_radius": 10,
      "min_height": 52
    },
    "tertiary_text": {
      "bg": "transparent",
      "fg": "muted",
      "border": null,
      "padding": [0, 0],
      "font_style": "body",
      "icon_left": "← "
    },
    "icon_round": {
      "bg": "transparent",
      "fg": "ink",
      "border": { "color": "line_firm", "width": 1 },
      "size": 36,
      "corner_radius": 18
    }
  },
  "segmented_control": {
    "container_border": { "color": "line_firm", "width": 1 },
    "item": {
      "padding": [12, 0],
      "font_style": "caption",
      "active_bg": "vermillion",
      "active_fg": "#f7f1e4",
      "inactive_fg": "ink",
      "border_left": { "color": "line_firm", "width": 1, "first_item": false }
    }
  },
  "toggle": {
    "size": [44, 24],
    "track_off_light": { "rgba": [0, 0, 0, 0.15] },
