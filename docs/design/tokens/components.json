    "thumb_size": 20,
    "thumb_inset": 2,
    "tween_ms": 200
  },
  "row": {
    "padding": [14, 0],
    "divider": { "color": "line", "width": 1 }
  },
  "stone": {
    "shadow": { "color": "#000000", "alpha": 0.30, "y": 1, "blur": 2 },
    "last_move_dot_radius": 2,
    "win_outline_width": 1.5
  },
  "footer_dot": {
    "size": 6,
    "color": "gold",
    "gap": 8
  },
  "help_section": {
    "ideogram_color": "gold",
    "ideogram_width": 32,
    "row_gap": 16,
    "title_size": 16,
    "title_weight": 600,
    "body_color": "ink_soft",
    "body_size": 14,
    "section_gap": 24
